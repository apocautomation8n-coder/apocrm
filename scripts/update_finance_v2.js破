import pg from 'pg'
import dotenv from 'dotenv'
dotenv.config()

const config = {
  connectionString: process.env.DATABASE_URL || `postgresql://postgres:ulIB78QjiaIrfGKC@db.kckmipvuvdbfsflxzynf.supabase.co:5432/postgres`,
  ssl: { rejectUnauthorized: false }
}

async function main() {
  const client = new pg.Client(config)
  await client.connect()
  console.log('Connected to database')

  try {
    // 1. Update bank_accounts
    await client.query(`
      ALTER TABLE bank_accounts 
      ADD COLUMN IF NOT EXISTS ach TEXT,
      ADD COLUMN IF NOT EXISTS wire TEXT,
      ADD COLUMN IF NOT EXISTS iban TEXT;
    `)
    console.log('Updated bank_accounts with ach, wire, iban')

    // 2. Update finance_transactions
    await client.query(`
      ALTER TABLE finance_transactions 
      ADD COLUMN IF NOT EXISTS project_id UUID REFERENCES finance_transactions(id),
      ADD COLUMN IF NOT EXISTS bank_account_id UUID REFERENCES bank_accounts(id);
    `)
    console.log('Updated finance_transactions with project_id and bank_account_id')

    // 3. Update expenses
    await client.query(`
      ALTER TABLE expenses 
      ADD COLUMN IF NOT EXISTS bank_account_id UUID REFERENCES bank_accounts(id);
    `)
    console.log('Updated expenses with bank_account_id')

  } catch (err) {
    console.error('Error during migration:', err)
  } finally {
    await client.end()
  }
}

main()
